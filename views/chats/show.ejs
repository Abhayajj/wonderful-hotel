<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-4">
  <div class="col-lg-8">
    
    <!-- Top Back navigation and header info -->
    <div class="d-flex align-items-center gap-3 mb-3">
      <a href="/chats" class="btn btn-outline-secondary btn-sm rounded-circle px-2 py-1">
        <i class="fa-solid fa-arrow-left"></i>
      </a>
      <h4 class="fw-bold text-dark mb-0">Chat Room</h4>
    </div>

    <!-- Active Listing Header Card -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
      <div class="card-body p-3 d-flex align-items-center gap-3">
        <img src="<%= listing.image %>" alt="<%= listing.title %>" class="rounded-3 shadow-xs" style="width: 80px; height: 60px; object-fit: cover;">
        <div>
          <h6 class="fw-bold text-dark mb-1"><%= listing.title %></h6>
          <p class="text-secondary mb-0 small"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></p>
          <span class="badge bg-danger-subtle text-danger rounded-pill px-2.5 py-1 small fw-semibold mt-1">
            Chatting with @<%= receiver.username %>
          </span>
        </div>
      </div>
    </div>

    <!-- Chat Box Window -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white d-flex flex-column" style="height: 50vh;">
      <div class="card-body p-4 overflow-y-auto flex-grow-1" id="chat-messages" style="background-color: #f8f9fa;">
        <% if (messages.length === 0) { %>
          <div class="text-center py-5 text-secondary opacity-75" id="no-messages-placeholder">
            <i class="fa-regular fa-paper-plane fs-1 mb-2 text-danger"></i>
            <p>Send a message to start the conversation!</p>
          </div>
        <% } else { %>
          <% for (let msg of messages) { %>
            <% const isMe = msg.sender._id ? msg.sender._id.equals(currUser._id) : msg.sender.equals(currUser._id); %>
            <div class="d-flex <%= isMe ? 'justify-content-end' : 'justify-content-start' %> mb-3 message-bubble" data-msg-id="<%= msg._id %>" data-is-me="<%= isMe %>">
              <div class="max-w-75 p-3 rounded-4 <%= isMe ? 'bg-danger text-white rounded-br-0' : 'bg-white border text-dark rounded-bl-0' %> shadow-xs">
                <% if (msg.image) { %>
                  <a href="<%= msg.image %>" target="_blank">
                    <img src="<%= msg.image %>" class="img-fluid rounded-3 mb-2" style="max-height: 220px; max-width: 100%; object-fit: cover; display: block;" alt="Shared Image">
                  </a>
                <% } %>
                <% if (msg.text) { %>
                  <p class="mb-1 small" style="line-height: 1.4;"><%= msg.text %></p>
                <% } %>
                <div class="text-end d-flex align-items-center justify-content-end gap-1" style="font-size: 9px; opacity: 0.85;">
                  <span><%= new Date(msg.createdAt).toLocaleTimeString("en-IN", { hour: '2-digit', minute: '2-digit' }) %></span>
                  <% if (isMe) { %>
                    <span class="read-status-icon">
                      <% if (msg.read) { %>
                        <i class="fa-solid fa-check-double text-info"></i>
                      <% } else { %>
                        <i class="fa-solid fa-check text-secondary opacity-75"></i>
                      <% } %>
                    </span>
                  <% } %>
                </div>
              </div>
            </div>
          <% } %>
        <% } %>
        <div id="typing-indicator" class="d-none text-muted small py-2 px-3 mb-2 align-self-start bg-light rounded-pill border" style="font-size: 11px; max-width: max-content;">
          <i class="fa-solid fa-ellipsis fa-bounce text-danger me-1"></i> <span id="typing-username" class="fw-bold"></span> is typing...
        </div>
      </div>

      <!-- Chat Form Input Area -->
      <div class="card-footer bg-white border-top p-3">
        <form id="chat-form" class="needs-validation" novalidate>
          <div class="input-group">
            <button class="btn btn-outline-secondary rounded-start-pill px-3 border-end-0" type="button" id="paperclip-btn" title="Attach Image">
              <i class="fa-solid fa-paperclip"></i>
            </button>
            <input type="file" id="chat-file-input" accept="image/*" style="display: none;">
            <input type="text" id="chat-input" class="form-control py-2.5 px-3 border-start-0" placeholder="Type your message here..." required autocomplete="off">
            <button class="btn btn-danger rounded-end-pill px-4" type="submit">
              <i class="fa-solid fa-paper-plane"></i>
            </button>
          </div>
          <!-- Upload Progress Bar -->
          <div id="upload-progress" class="d-none progress mt-2" style="height: 4px;">
            <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Include Socket.io client script -->
<script src="/socket.io/socket.io.js"></script>
<script>
  const socket = io();
  const roomId = "<%= roomId %>";
  const currUserId = "<%= currUser._id %>";
  const currUsername = "<%= currUser.username %>";
  const receiverId = "<%= receiver._id %>";
  const listingId = "<%= listing._id %>";

  const chatMessages = document.getElementById("chat-messages");
  const chatForm = document.getElementById("chat-form");
  const chatInput = document.getElementById("chat-input");
  const noMessagesPlaceholder = document.getElementById("no-messages-placeholder");
  const typingIndicator = document.getElementById("typing-indicator");
  const typingUsername = document.getElementById("typing-username");
  
  const fileInput = document.getElementById("chat-file-input");
  const paperclipBtn = document.getElementById("paperclip-btn");
  const uploadProgress = document.getElementById("upload-progress");

  // Scroll to bottom on initial load
  chatMessages.scrollTop = chatMessages.scrollHeight;

  // Join the unique private room
  socket.emit("join_room", { roomId, userId: currUserId, otherId: receiverId, listingId });

  // Handle Form Submission
  chatForm.addEventListener("submit", (e) => {
    e.preventDefault();
    const text = chatInput.value.trim();
    if (!text) return;

    // Send message payload via websockets
    socket.emit("send_message", {
      senderId: currUserId,
      receiverId,
      listingId,
      text,
      image: "",
      roomId
    });

    chatInput.value = "";
    stopTypingImmediately();
  });

  // Typing Indicator Logic
  let typing = false;
  let timeout = undefined;

  function timeoutFunction() {
    typing = false;
    socket.emit("stop_typing", { roomId });
  }

  chatInput.addEventListener("input", (e) => {
    if (typing === false) {
      typing = true;
      socket.emit("typing", { roomId, username: currUsername });
      timeout = setTimeout(timeoutFunction, 2500);
    } else {
      clearTimeout(timeout);
      timeout = setTimeout(timeoutFunction, 2500);
    }
  });

  function stopTypingImmediately() {
    clearTimeout(timeout);
    typing = false;
    socket.emit("stop_typing", { roomId });
  }

  socket.on("typing", (data) => {
    typingUsername.textContent = data.username;
    typingIndicator.classList.remove("d-none");
    chatMessages.scrollTop = chatMessages.scrollHeight;
  });

  socket.on("stop_typing", () => {
    typingIndicator.classList.add("d-none");
  });

  // Image Upload Logic
  paperclipBtn.addEventListener("click", () => fileInput.click());

  fileInput.addEventListener("change", async () => {
    const file = fileInput.files[0];
    if (!file) return;

    const formData = new FormData();
    formData.append("chatImage", file);

    uploadProgress.classList.remove("d-none");

    try {
      const response = await fetch("/chats/upload", {
        method: "POST",
        body: formData,
      });

      if (!response.ok) {
        throw new Error("Upload failed");
      }

      const result = await response.json();
      
      socket.emit("send_message", {
        senderId: currUserId,
        receiverId,
        listingId,
        text: "",
        image: result.imageUrl,
        roomId
      });
    } catch (err) {
      alert("Image upload failed: " + err.message);
    } finally {
      uploadProgress.classList.add("d-none");
      fileInput.value = "";
    }
  });

  // Listen for incoming messages
  socket.on("receive_message", (data) => {
    if (noMessagesPlaceholder) {
      noMessagesPlaceholder.remove();
    }

    const isMe = data.sender === currUserId;
    const timeStr = new Date(data.createdAt).toLocaleTimeString("en-IN", { hour: '2-digit', minute: '2-digit' });

    const messageDiv = document.createElement("div");
    messageDiv.className = `d-flex ${isMe ? 'justify-content-end' : 'justify-content-start'} mb-3 message-bubble`;
    messageDiv.setAttribute("data-msg-id", data._id);
    messageDiv.setAttribute("data-is-me", isMe);

    let imageHtml = "";
    if (data.image) {
      imageHtml = `
        <a href="${data.image}" target="_blank">
          <img src="${data.image}" class="img-fluid rounded-3 mb-2" style="max-height: 220px; max-width: 100%; object-fit: cover; display: block;" alt="Shared Image">
        </a>
      `;
    }

    let checkmarkHtml = "";
    if (isMe) {
      checkmarkHtml = `
        <span class="read-status-icon">
          ${data.read ? '<i class="fa-solid fa-check-double text-info"></i>' : '<i class="fa-solid fa-check text-secondary opacity-75"></i>'}
        </span>
      `;
    }

    let textHtml = "";
    if (data.text) {
      textHtml = `<p class="mb-1 small" style="line-height: 1.4;">${escapeHTML(data.text)}</p>`;
    }

    messageDiv.innerHTML = `
      <div class="max-w-75 p-3 rounded-4 ${isMe ? 'bg-danger text-white rounded-br-0' : 'bg-white border text-dark rounded-bl-0'} shadow-xs">
        ${imageHtml}
        ${textHtml}
        <div class="text-end d-flex align-items-center justify-content-end gap-1" style="font-size: 9px; opacity: 0.85;">
          <span>${timeStr}</span>
          ${checkmarkHtml}
        </div>
      </div>
    `;

    chatMessages.insertBefore(messageDiv, typingIndicator);
    chatMessages.scrollTop = chatMessages.scrollHeight;

    // Auto-read receipt: send verification back to sender if we are the receiver
    if (!isMe) {
      socket.emit("mark_read", { messageId: data._id, roomId });
    }
  });

  socket.on("messages_read", (data) => {
    document.querySelectorAll(".message-bubble[data-is-me='true'] .read-status-icon").forEach(span => {
      span.innerHTML = `<i class="fa-solid fa-check-double text-info"></i>`;
    });
  });

  function escapeHTML(str) {
    return str
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
</script>
