<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-4">
  <div class="col-lg-8">
    <div class="d-flex align-items-center justify-content-between mb-4">
      <div>
        <h2 class="fw-bold text-dark mb-0"><i class="fa-solid fa-message text-danger me-2"></i>My Chats</h2>
        <p class="text-muted mb-0">Direct messages with property hosts and guests</p>
      </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
      <div class="card-header bg-white border-bottom py-3 px-4">
        <h5 class="fw-bold text-dark mb-0">Conversations</h5>
      </div>
      <div class="card-body p-0">
        <% if (conversations.length === 0) { %>
          <div class="text-center py-5 text-secondary">
            <i class="fa-regular fa-comments fs-1 mb-3 text-secondary opacity-50 d-block"></i>
            <h5 class="fw-bold text-dark">No messages yet!</h5>
            <p class="text-secondary mb-0">When you chat with a host or guest, the conversation will show up here.</p>
          </div>
        <% } else { %>
          <div class="list-group list-group-flush">
            <% for (let chat of conversations) { %>
              <a href="/chats/<%= chat.listing._id %>/<%= chat.otherUser._id %>" class="list-group-item list-group-item-action p-4 border-0 border-bottom d-flex align-items-center gap-3 transition hover-bg-light">
                <img src="<%= chat.listing.image %>" alt="<%= chat.listing.title %>" class="rounded-3 shadow-xs" style="width: 72px; height: 54px; object-fit: cover;">
                <div class="flex-grow-1 min-w-0">
                  <div class="d-flex justify-content-between align-items-baseline mb-1">
                    <h6 class="fw-bold text-dark text-truncate mb-0" style="max-width: 250px;">
                      <%= chat.listing.title %>
                    </h6>
                    <small class="text-muted">
                      <%= new Date(chat.lastMessageTime).toLocaleDateString("en-IN", { hour: '2-digit', minute: '2-digit' }) %>
                    </small>
                  </div>
                  <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge bg-danger-subtle text-danger rounded-pill px-2 py-1 small fw-semibold">
                      @<%= chat.otherUser.username %>
                    </span>
                  </div>
                  <p class="text-secondary text-truncate mb-0 small font-monospace"><%= chat.lastMessage %></p>
                </div>
                <div class="text-danger fs-5">
                  <i class="fa-solid fa-chevron-right"></i>
                </div>
              </a>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
