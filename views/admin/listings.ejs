<% layout("/layouts/boilerplate") %>
<div class="row mb-4">
  <div class="col-12 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
    <div>
      <h1 class="fw-bold text-dark d-flex align-items-center gap-2">
        <i class="fa-solid fa-house-laptop text-danger"></i> Manage Listings
      </h1>
      <p class="text-secondary mb-0">Browse and manage all properties on the platform.</p>
    </div>
    <div class="btn-group shadow-sm">
      <a href="/admin/dashboard" class="btn btn-outline-danger">Dashboard</a>
      <a href="/admin/users" class="btn btn-outline-danger">Users</a>
      <a href="/admin/listings" class="btn btn-danger active">Listings</a>
      <a href="/admin/bookings" class="btn btn-outline-danger">Bookings</a>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm rounded-4 mb-5">
  <div class="card-header bg-white border-bottom py-3 px-4">
    <h5 class="fw-bold text-dark mb-0">
      <i class="fa-solid fa-house-chimney me-1 text-danger"></i> All Active Listings
    </h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="px-4 py-3 border-0">Property</th>
            <th class="py-3 border-0">Location</th>
            <th class="py-3 border-0">Owner</th>
            <th class="py-3 border-0 text-end">Price / Night</th>
            <th class="py-3 border-0 text-center">Category</th>
            <th class="px-4 py-3 border-0 text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (allListings.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5 text-secondary">
                <i class="fa-regular fa-folder-open fs-2 mb-3 d-block text-secondary opacity-50"></i>
                No listings found.
              </td>
            </tr>
          <% } else { %>
            <% for (let listing of allListings) { %>
              <tr>
                <td class="px-4 py-3">
                  <div class="d-flex align-items-center gap-3">
                    <img src="<%= listing.image || '/images/default.jpg' %>" alt="<%= listing.title %>" class="rounded-3 shadow-xs" style="width: 56px; height: 42px; object-fit: cover;">
                    <div>
                      <a href="/listings/<%= listing._id %>" class="fw-semibold text-dark text-decoration-none hover-danger d-block">
                        <%= listing.title %>
                      </a>
                      <span class="text-muted small text-truncate d-inline-block" style="max-width: 250px;"><%= listing.description %></span>
                    </div>
                  </div>
                </td>
                <td class="py-3 text-secondary">
                  <%= listing.location %>, <%= listing.country %>
                </td>
                <td class="py-3">
                  <span class="fw-semibold text-dark"><%= listing.owner ? listing.owner.username : 'Unknown Owner' %></span>
                </td>
                <td class="py-3 text-end fw-bold text-dark">
                  <%= listing.price.toLocaleString("en-IN", { style: "currency", currency: "INR", maximumFractionDigits: 0 }) %>
                </td>
                <td class="py-3 text-center">
                  <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-semibold"><%= listing.category %></span>
                </td>
                <td class="px-4 py-3 text-end">
                  <div class="d-flex justify-content-end gap-2">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-secondary px-3 rounded-pill fw-semibold">
                      Edit
                    </a>
                    <form action="/admin/listings/<%= listing._id %>?_method=DELETE" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this listing? All of its bookings and reviews will be deleted too!');">
                      <button type="submit" class="btn btn-sm btn-danger px-3 rounded-pill fw-semibold">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% } %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
