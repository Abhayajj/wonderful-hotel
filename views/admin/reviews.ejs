<% layout("/layouts/boilerplate") %>

<div class="container my-4">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
      <a href="/admin/dashboard" class="btn btn-outline-dark btn-sm rounded-pill mb-2">
        <i class="fa-solid fa-arrow-left me-1"></i>Back to Dashboard
      </a>
      <h2 class="fw-bold text-dark m-0">
        <i class="fa-solid fa-triangle-exclamation text-warning me-2"></i>Flagged Reviews Queue
      </h2>
      <p class="text-secondary small mb-0">Moderation queue for user-reported guest reviews.</p>
    </div>
    <span class="badge bg-warning text-dark py-2 px-3 rounded-pill fw-bold">
      <%= flaggedReviews.length %> pending review<%= flaggedReviews.length !== 1 ? 's' : '' %>
    </span>
  </div>

  <% if (flaggedReviews.length === 0) { %>
    <div class="card border-0 shadow-sm rounded-4 text-center p-5 bg-white">
      <div class="card-body py-5">
        <i class="fa-regular fa-circle-check text-success display-1 mb-4"></i>
        <h4 class="fw-bold text-dark mb-2">All Clear!</h4>
        <p class="text-secondary mb-0">There are no flagged or reported guest reviews awaiting moderation.</p>
      </div>
    </div>
  <% } else { %>
    <div class="row g-3">
      <% for (let r of flaggedReviews) { %>
        <div class="col-lg-6">
          <div class="card h-100 border-0 shadow-sm rounded-4 p-4 bg-white">
            <div class="d-flex flex-column h-100 justify-content-between">
              <div>
                <!-- Header: Listing & Author Info -->
                <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2 border-bottom pb-3">
                  <div>
                    <% if (r.listing) { %>
                      <h5 class="fw-bold text-dark mb-0"><%= r.listing.title %></h5>
                      <span class="text-secondary small">
                        <i class="fa-solid fa-location-dot me-1 text-danger"></i><%= r.listing.location %>, <%= r.listing.country %>
                      </span>
                    <% } else { %>
                      <span class="badge bg-secondary text-white rounded-pill">Deleted Listing</span>
                    <% } %>
                  </div>
                  <div class="text-warning small">
                    <% for(let i = 1; i <= 5; i++) { %>
                      <i class="<%= i <= r.rating ? 'fa-solid fa-star' : 'fa-regular fa-star' %>"></i>
                    <% } %>
                  </div>
                </div>

                <!-- Report details badge -->
                <div class="mb-3">
                  <span class="badge bg-danger-subtle text-danger border border-danger-subtle py-1.5 px-3 rounded-pill small">
                    <i class="fa-solid fa-circle-exclamation me-1"></i>Reported Reason: <strong><%= r.flaggedReason %></strong>
                  </span>
                </div>

                <!-- Comment content -->
                <div class="p-3 bg-light rounded-4 mb-3 border border-light-subtle">
                  <span class="text-secondary small d-block mb-1">Guest Comment (@<%= r.author ? r.author.username : 'anonymous' %>):</span>
                  <p class="text-dark mb-0 small" style="line-height: 1.5; font-style: italic;">
                    "<%= r.comment %>"
                  </p>
                </div>
              </div>

              <!-- Action button area -->
              <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                <span class="text-secondary small">Posted: <%= new Date(r.createdAt).toLocaleDateString() %></span>
                <div class="d-flex gap-2">
                  <!-- Form: Dismiss Flag / Approve -->
                  <form action="/admin/reviews/<%= r._id %>/approve" method="POST" class="m-0">
                    <button class="btn btn-sm btn-outline-success rounded-pill px-3 py-1.5 fw-bold text-xs" style="font-size: 11px;">
                      <i class="fa-solid fa-check me-1"></i>Approve & Dismiss
                    </button>
                  </form>
                  <!-- Form: Delete Review -->
                  <form action="/admin/reviews/<%= r._id %>?_method=DELETE" method="POST" class="m-0">
                    <button class="btn btn-sm btn-danger rounded-pill px-3 py-1.5 fw-bold text-xs" style="font-size: 11px;">
                      <i class="fa-solid fa-trash me-1"></i>Delete Review
                    </button>
                  </form>
                </div>
              </div>

            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>
</div>
