<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center">
  <div class="col-lg-6 col-md-8">
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
      <div class="text-center mb-4">
        <h2 class="fw-bold text-dark mb-1"><i class="fa-solid fa-comments text-danger me-2"></i>Share Your Feedback</h2>
        <p class="text-muted">Tell us about your experience and how we can make WonderFull better.</p>
      </div>
      
      <form action="/listings/recommend" method="POST" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="name" class="form-label fw-semibold text-secondary">Full Name</label>
          <input type="text" id="name" name="name" class="form-control rounded-3" placeholder="Jane Doe" required>
          <div class="invalid-feedback">Please enter your name.</div>
        </div>
        
        <div class="mb-3">
          <label for="email" class="form-label fw-semibold text-secondary">Email Address</label>
          <input type="email" id="email" name="email" class="form-control rounded-3" placeholder="jane@example.com" required>
          <div class="invalid-feedback">Please enter a valid email address.</div>
        </div>
        
        <div class="mb-4">
          <label for="recommendation" class="form-label fw-semibold text-secondary">Your Recommendation or Feedback</label>
          <textarea id="recommendation" name="recommendation" rows="5" class="form-control rounded-3" placeholder="What are your thoughts or suggestions?" required></textarea>
          <div class="invalid-feedback">Please write down your feedback.</div>
        </div>
        
        <button type="submit" class="btn btn-danger w-100 py-3 rounded-pill fw-bold fs-5 shadow-sm">Submit Recommendation</button>
      </form>
    </div>
  </div>
</div>
