<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center text-center">
  <div class="col-lg-6 col-md-8">
    <div class="card border-0 shadow-sm rounded-4 p-5 bg-white">
      <div class="mb-4">
        <i class="fa-solid fa-circle-check text-success fs-1"></i>
      </div>
      <h2 class="fw-bold text-dark mb-2">Thank You, <%= recommendation.name %>!</h2>
      <p class="text-muted fs-5 mb-4">We've received your feedback and recommendations. Your insight helps us make WonderFull even more wonderful for our global travel community.</p>
      
      <div class="bg-light p-3 rounded-3 mb-4 text-start">
        <span class="text-muted d-block small uppercase fw-bold tracking-wider mb-2">Your Submitted Note:</span>
        <p class="text-secondary italic mb-0">"<%= recommendation.recommendation %>"</p>
      </div>

      <div class="d-flex justify-content-center gap-3">
        <a href="/listings" class="btn btn-danger px-4 py-2 rounded-pill fw-semibold">Back to Explore</a>
      </div>
    </div>
  </div>
</div>
