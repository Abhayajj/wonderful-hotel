<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-5">
  <div class="col-md-6 col-lg-5">
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle p-3 mb-2" style="width: 60px; height: 60px;">
          <i class="fa-solid fa-right-to-bracket fs-3"></i>
        </div>
        <h3 class="fw-bold text-dark mb-1">Welcome Back</h3>
        <p class="text-muted small">Log in to manage bookings and explore listings</p>
      </div>

      <form method="POST" action="/login" novalidate class="needs-validation">
        <div class="mb-3">
          <label for="username" class="form-label fw-semibold text-secondary">Username</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0 rounded-start-3 text-secondary"><i class="fa-regular fa-user"></i></span>
            <input name="username" id="username" placeholder="Enter username" type="text" class="form-control border-start-0 rounded-end-3" required />
            <div class="invalid-feedback">Please enter your username.</div>
          </div>
        </div>

        <div class="mb-4">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <label for="password" class="form-label fw-semibold text-secondary mb-0">Password</label>
            <a href="/forgot" class="text-danger small fw-semibold text-decoration-none">Forgot Password?</a>
          </div>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0 rounded-start-3 text-secondary"><i class="fa-solid fa-lock"></i></span>
            <input name="password" id="password" placeholder="Enter password" type="password" class="form-control border-start-0 rounded-end-3" required />
            <div class="invalid-feedback">Please enter your password.</div>
          </div>
        </div>

        <button class="btn btn-danger w-100 py-2.5 rounded-pill fw-bold shadow-sm mb-3">Log In</button>
      </form>

      <div class="text-center my-3">
        <span class="text-muted small">or connect with</span>
      </div>
      <div class="mb-3">
        <a href="/auth/google" class="btn btn-outline-danger w-100 rounded-pill d-flex align-items-center justify-content-center gap-2 py-2 small fw-semibold">
          <i class="fa-brands fa-google"></i> Google Login
        </a>
      </div>

      <div class="text-center pt-2 border-top">
        <p class="text-muted mb-0 small">Don't have an account yet? <a href="/signup" class="text-danger fw-bold text-decoration-none">Sign Up</a></p>
      </div>
    </div>
  </div>
</div>
