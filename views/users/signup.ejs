<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-5">
  <div class="col-md-6 col-lg-5">
    <div class="card border-0 shadow-sm rounded-4 p-4 bg-white">
      <div class="text-center mb-4">
        <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle text-danger rounded-circle p-3 mb-2" style="width: 60px; height: 60px;">
          <i class="fa-solid fa-user-plus fs-3"></i>
        </div>
        <h3 class="fw-bold text-dark mb-1">Create Account</h3>
        <p class="text-muted small">Join WonderFull today to discover or host amazing places</p>
      </div>

      <form method="POST" action="/signup" novalidate class="needs-validation">
        <div class="mb-3">
          <label for="username" class="form-label fw-semibold text-secondary">Username</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0 rounded-start-3 text-secondary"><i class="fa-regular fa-user"></i></span>
            <input name="username" id="username" placeholder="Choose a username" type="text" class="form-control border-start-0 rounded-end-3" required />
            <div class="invalid-feedback">Please enter a username.</div>
          </div>
        </div>

        <div class="mb-3">
          <label for="email" class="form-label fw-semibold text-secondary">Email Address</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0 rounded-start-3 text-secondary"><i class="fa-regular fa-envelope"></i></span>
            <input name="email" id="email" placeholder="example@email.com" type="email" class="form-control border-start-0 rounded-end-3" required />
            <div class="invalid-feedback">Please enter a valid email address.</div>
          </div>
        </div>

        <div class="mb-4">
          <label for="password" class="form-label fw-semibold text-secondary">Password</label>
          <div class="input-group">
            <span class="input-group-text bg-light border-end-0 rounded-start-3 text-secondary"><i class="fa-solid fa-lock"></i></span>
            <input name="password" id="password" placeholder="Min. 8 characters" type="password" class="form-control border-start-0 rounded-end-3" required />
            <div class="invalid-feedback">Please enter your password.</div>
          </div>
        </div>

        <button class="btn btn-danger w-100 py-2.5 rounded-pill fw-bold shadow-sm mb-3">Sign Up</button>
      </form>

      <div class="text-center pt-2 border-top">
        <p class="text-muted mb-0 small">Already have an account? <a href="/login" class="text-danger fw-bold text-decoration-none">Log In</a></p>
      </div>
    </div>
  </div>
</div>
