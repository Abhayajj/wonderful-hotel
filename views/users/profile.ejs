<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-4">
  <div class="col-lg-10">
    <div class="row g-4">
      
      <!-- Left Column: Profile Card Info -->
      <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white sticky-top" style="top: 100px; z-index: 10;">
          <div class="position-relative d-inline-block mx-auto mb-3">
            <img src="<%= profileUser.profileImage || '/images/default-avatar.png' %>" 
                 class="rounded-circle border border-3 border-danger shadow-sm" 
                 style="width: 140px; height: 140px; object-fit: cover;" 
                 alt="User Avatar"
                 onerror="this.src='/images/default-avatar.png';">
            <% if (currUser && currUser._id.equals(profileUser._id)) { %>
              <a href="/profile/edit" class="btn btn-sm btn-danger rounded-circle position-absolute bottom-0 end-0 p-2 shadow" style="width: 36px; height: 36px;" title="Edit Profile">
                <i class="fa-solid fa-camera"></i>
              </a>
            <% } %>
          </div>
          
          <h4 class="fw-bold text-dark mb-1">@<%= profileUser.username %></h4>
          <span class="badge bg-danger-subtle text-danger rounded-pill px-3 py-1 fw-bold uppercase fs-7 mb-3"><%= profileUser.role %></span>
          
          <hr class="my-3 opacity-25">
          
          <div class="text-start">
            <h6 class="fw-bold text-secondary text-uppercase small mb-2">About</h6>
            <p class="text-secondary small mb-3" style="line-height: 1.6;">
              <%= profileUser.bio || "No biography provided yet." %>
            </p>
            
            <div class="d-flex align-items-center gap-2 mb-2 text-secondary small">
              <i class="fa-regular fa-calendar text-danger"></i>
              <span>Member since <%= new Date(profileUser.createdAt).toLocaleDateString("en-IN", { month: 'long', year: 'numeric' }) %></span>
            </div>
            
            <% if (profileUser.phone) { %>
              <div class="d-flex align-items-center gap-2 mb-2 text-secondary small">
                <i class="fa-solid fa-phone text-danger"></i>
                <span><%= profileUser.phone %></span>
              </div>
            <% } %>

            <% if (currUser && (currUser._id.equals(profileUser._id) || currUser.role === 'admin')) { %>
              <div class="d-flex align-items-center gap-2 mb-2 text-secondary small">
                <i class="fa-regular fa-envelope text-danger"></i>
                <span><%= profileUser.email %></span>
              </div>
            <% } %>
          </div>
          
          <% if (currUser && currUser._id.equals(profileUser._id)) { %>
            <a href="/profile/edit" class="btn btn-outline-danger w-100 rounded-pill fw-bold btn-sm mt-3">
              <i class="fa-solid fa-user-pen me-1"></i>Edit Profile
            </a>
          <% } %>
        </div>
      </div>
      
      <!-- Right Column: Host Rating & Owned Listings -->
      <div class="col-md-8">
        <!-- Host Metrics Cards -->
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4 bg-white">
          <h5 class="fw-bold text-dark mb-4"><i class="fa-solid fa-ranking-star text-danger me-2"></i>Host Reputation</h5>
          <div class="row g-3">
            <div class="col-6 col-sm-4 text-center border-end">
              <h2 class="fw-bold text-dark mb-0"><%= hostRating %></h2>
              <span class="text-muted small">Average Rating</span>
            </div>
            <div class="col-6 col-sm-4 text-center border-end-sm">
              <h2 class="fw-bold text-dark mb-0"><%= totalReviews %></h2>
              <span class="text-muted small">Total Reviews</span>
            </div>
            <div class="col-12 col-sm-4 text-center mt-3 mt-sm-0">
              <h2 class="fw-bold text-dark mb-0"><%= hostListings.length %></h2>
              <span class="text-muted small">Listed Properties</span>
            </div>
          </div>
        </div>
        
        <!-- Host's Listings Grid -->
        <h4 class="fw-bold text-dark mb-3">Stays Hosted by @<%= profileUser.username %></h4>
        
        <% if (hostListings.length === 0) { %>
          <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white">
            <i class="fa-regular fa-building fs-1 text-secondary opacity-50 mb-3 d-block"></i>
            <h5 class="fw-bold text-dark">No stays listed yet!</h5>
            <p class="text-secondary small mb-0">This host hasn't registered any accommodations on WonderFull yet.</p>
          </div>
        <% } else { %>
          <div class="row g-4">
            <% for (let listing of hostListings) { %>
              <div class="col-sm-6">
                <a href="/listings/<%= listing._id %>" class="text-decoration-none">
                  <div class="card border-0 shadow-sm rounded-4 overflow-hidden card-hover h-100 bg-white">
                    <img src="<%= listing.image || '/images/default.jpg' %>" class="card-img-top" style="height: 200px; object-fit: cover;" alt="<%= listing.title %>">
                    <div class="card-body p-3">
                      <h6 class="fw-bold text-dark mb-1 text-truncate"><%= listing.title %></h6>
                      <p class="text-secondary mb-2 small"><i class="fa-solid fa-location-dot me-1 text-danger"></i><%= listing.location %>, <%= listing.country %></p>
                      <p class="card-text text-secondary mb-0 small">
                        <span class="fw-bold text-dark">&#8377; <%= listing.price.toLocaleString("en-IN") %></span> <span class="text-muted">/ night</span>
                      </p>
                    </div>
                  </div>
                </a>
              </div>
            <% } %>
          </div>
        <% } %>
      </div>
      
    </div>
  </div>
</div>
