<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-5">
  <div class="col-md-8 col-lg-6">
    <div class="card border-0 shadow rounded-4 p-5 text-center bg-white">

      <!-- Success Icon -->
      <div class="mb-4">
        <div class="d-inline-flex align-items-center justify-content-center rounded-circle mb-3"
          style="width: 90px; height: 90px; background: linear-gradient(135deg, #d4edda, #a8dbb0);">
          <i class="fa-solid fa-circle-check text-success" style="font-size: 2.8rem;"></i>
        </div>
        <h2 class="fw-bold text-dark mb-1">Booking Confirmed!</h2>
        <% if (razorpayEnabled) { %>
          <p class="text-success fw-semibold small">
            <i class="fa-solid fa-lock me-1"></i>Payment verified via Razorpay
          </p>
        <% } else { %>
          <div class="alert alert-warning border-0 rounded-3 py-2 px-3 d-inline-block small mb-2">
            <i class="fa-solid fa-circle-info me-1"></i>
            <strong>Demo Mode</strong> — No real payment processed.
            Add Razorpay keys to <code>.env</code> to enable real payments.
          </div>
        <% } %>
      </div>

      <!-- Booking Details -->
      <div class="card bg-light border-0 rounded-4 p-4 text-start mb-4">
        <div class="d-flex align-items-center gap-3 mb-3 pb-3 border-bottom">
          <% if (booking.listing.image) { %>
            <img src="<%= booking.listing.image %>"
              alt="<%= booking.listing.title %>"
              class="rounded-3"
              style="width: 80px; height: 60px; object-fit: cover; flex-shrink: 0;">
          <% } %>
          <div>
            <h5 class="fw-bold text-dark mb-0"><%= booking.listing.title %></h5>
            <small class="text-secondary">
              <i class="fa-solid fa-location-dot me-1"></i>
              <%= booking.listing.location %>, <%= booking.listing.country %>
            </small>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-6">
            <span class="text-muted d-block small fw-semibold text-uppercase">Check-In</span>
            <span class="fw-bold text-dark">
              <%= new Date(booking.checkIn).toLocaleDateString("en-IN", { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
            </span>
          </div>
          <div class="col-6">
            <span class="text-muted d-block small fw-semibold text-uppercase">Check-Out</span>
            <span class="fw-bold text-dark">
              <%= new Date(booking.checkOut).toLocaleDateString("en-IN", { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
            </span>
          </div>
          <div class="col-6">
            <span class="text-muted d-block small fw-semibold text-uppercase">Total Paid</span>
            <span class="fw-bold text-danger fs-5">
              &#8377; <%= booking.totalPrice.toLocaleString("en-IN") %>
            </span>
          </div>
          <div class="col-6">
            <span class="text-muted d-block small fw-semibold text-uppercase">Status</span>
            <span class="badge bg-success rounded-pill px-3 py-2">✓ Paid</span>
          </div>
          <div class="col-12">
            <span class="text-muted d-block small fw-semibold text-uppercase">Payment ID</span>
            <code class="text-secondary" style="font-size: 0.75rem; word-break: break-all;">
              <%= booking.paymentId %>
            </code>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="d-flex flex-column flex-sm-row gap-3 justify-content-center">
        <a href="/bookings/my-trips"
          class="btn btn-danger px-4 py-2 rounded-pill fw-bold shadow-sm">
          <i class="fa-solid fa-suitcase me-2"></i>View My Trips
        </a>
        <a href="/listings"
          class="btn btn-outline-dark px-4 py-2 rounded-pill fw-bold">
          Explore More Places
        </a>
      </div>
    </div>
  </div>
</div>
