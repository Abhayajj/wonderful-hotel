<% layout("/layouts/boilerplate") %>
<div class="row justify-content-center my-4">
  <div class="col-lg-10">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
      <div>
        <h2 class="fw-bold text-dark mb-0"><i class="fa-solid fa-suitcase text-danger me-2"></i>My Trips</h2>
        <p class="text-muted mb-0">Manage your active and completed bookings</p>
      </div>
      <a href="/listings" class="btn btn-outline-danger btn-sm px-3 py-2 rounded-pill fw-bold">
        <i class="fa-solid fa-compass me-1"></i>Find New Places
      </a>
    </div>

    <% if (bookings.length === 0) { %>
      <div class="card border-0 shadow-sm rounded-4 p-5 text-center bg-white my-5">
        <div class="mb-3 text-secondary">
          <i class="fa-solid fa-plane-departure fs-1"></i>
        </div>
        <h4 class="fw-bold text-dark">No trips booked yet!</h4>
        <p class="text-secondary mb-4">When you book an accommodation, it will show up here.</p>
        <div>
          <a href="/listings" class="btn btn-danger px-4 py-2 rounded-pill fw-bold shadow-sm">
            Start Exploring
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="row g-4">
        <% for(let booking of bookings) { %>
          <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white hover-card">
              <div class="row g-0">
                <div class="col-md-4 col-lg-3">
                  <img src="<%= booking.listing.image %>" class="img-fluid h-100 w-100" alt="<%= booking.listing.title %>" style="object-fit: cover; min-height: 180px; max-height: 240px;">
                </div>
                <div class="col-md-8 col-lg-9 p-4 d-flex flex-column justify-content-between">
                  <div>
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <div>
                        <h4 class="fw-bold text-dark mb-1">
                          <a href="/listings/<%= booking.listing._id %>" class="text-dark text-decoration-none hover-red">
                            <%= booking.listing.title %>
                          </a>
                        </h4>
                        <p class="text-muted small mb-0"><i class="fa-solid fa-location-dot me-1 text-secondary"></i><%= booking.listing.location %>, <%= booking.listing.country %></p>
                      </div>
                      <% if (booking.status === 'paid') { %>
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1.5 fw-bold uppercase fs-6">Paid</span>
                      <% } else if (booking.status === 'cancelled') { %>
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3 py-1.5 fw-bold uppercase fs-6">Cancelled</span>
                      <% } else if (booking.status === 'refunded') { %>
                        <span class="badge bg-info-subtle text-info border border-info-subtle rounded-pill px-3 py-1.5 fw-bold uppercase fs-6">Refunded</span>
                      <% } else { %>
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-1.5 fw-bold uppercase fs-6"><%= booking.status %></span>
                      <% } %>
                    </div>

                    <div class="row my-3 g-2 bg-light p-3 rounded-3 text-secondary small">
                      <div class="col-sm-4">
                        <span class="d-block uppercase text-muted fw-semibold">Check-In</span>
                        <span class="fw-bold text-dark fs-6"><%= new Date(booking.checkIn).toLocaleDateString("en-IN", { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                      </div>
                      <div class="col-sm-4">
                        <span class="d-block uppercase text-muted fw-semibold">Check-Out</span>
                        <span class="fw-bold text-dark fs-6"><%= new Date(booking.checkOut).toLocaleDateString("en-IN", { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                      </div>
                      <div class="col-sm-4">
                        <span class="d-block uppercase text-muted fw-semibold">Total Paid</span>
                        <span class="fw-bold text-danger fs-6">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                      </div>
                    </div>

                    <% if (booking.status === 'refunded' || booking.status === 'cancelled') { %>
                      <div class="my-3 p-3 bg-light rounded-3 border text-secondary small">
                        <div class="d-flex justify-content-between mb-1">
                          <span class="text-muted">Total Paid:</span>
                          <span class="text-dark fw-semibold">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                        </div>
                        <% if (booking.cancellationFee > 0) { %>
                          <div class="d-flex justify-content-between mb-1 text-danger">
                            <span>Cancellation Charge Deducted:</span>
                            <span class="fw-semibold">- &#8377; <%= booking.cancellationFee.toLocaleString("en-IN") %></span>
                          </div>
                          <div class="d-flex justify-content-between mb-1 text-success">
                            <span class="fw-semibold">Amount Refunded:</span>
                            <span class="fw-bold">&#8377; <%= booking.refundAmount.toLocaleString("en-IN") %></span>
                          </div>
                        <% } else { %>
                          <div class="d-flex justify-content-between mb-1 text-success">
                            <span class="fw-semibold">Amount Refunded:</span>
                            <span class="fw-bold">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                          </div>
                        <% } %>
                        <% if (booking.refundId) { %>
                          <div class="d-flex justify-content-between mt-2 pt-2 border-top text-muted small">
                            <span>Refund ID:</span>
                            <span class="font-monospace"><%= booking.refundId %></span>
                          </div>
                        <% } else { %>
                          <div class="d-flex justify-content-between mt-2 pt-2 border-top text-muted small">
                            <span>Refund Mode:</span>
                            <span>Simulated/UPI</span>
                          </div>
                        <% } %>
                      </div>
                    <% } %>
                  </div>

                  <div class="d-flex justify-content-between align-items-center mt-3 pt-2 border-top">
                    <span class="text-muted small">Booked on <%= new Date(booking.createdAt).toLocaleDateString("en-IN") %></span>
                    <div class="d-flex align-items-center gap-2">
                      <% if (booking.status === 'paid') { %>
                        <button class="btn btn-sm btn-outline-danger px-3 py-1.5 rounded-pill fw-bold" data-bs-toggle="modal" data-bs-target="#cancelModal-<%= booking._id %>">
                          <i class="fa-solid fa-ban me-1"></i>Cancel Booking
                        </button>

                        <!-- Cancellation Modal -->
                        <div class="modal fade" id="cancelModal-<%= booking._id %>" tabindex="-1" aria-labelledby="cancelModalLabel-<%= booking._id %>" aria-hidden="true">
                          <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content border-0 shadow-lg rounded-4 text-start bg-white">
                              <div class="modal-header border-bottom p-3">
                                <h5 class="modal-title fw-bold text-dark" id="cancelModalLabel-<%= booking._id %>">
                                  <i class="fa-solid fa-triangle-exclamation text-warning me-2"></i>Cancel Stay
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                              </div>
                              <div class="modal-body p-4">
                                <div class="alert alert-light border small text-muted mb-3 py-2 bg-light">
                                  <h6 class="fw-bold mb-1 text-dark text-uppercase small" style="font-size: 11px;">Cancellation Policy</h6>
                                  <ul class="mb-0 ps-3">
                                    <li>More than 72 hours before check-in: <strong>10% fee</strong></li>
                                    <li>Between 24 and 72 hours before check-in: <strong>25% fee</strong></li>
                                    <li>Less than 24 hours before check-in: <strong>50% fee</strong></li>
                                    <li>After check-in time: <strong>100% fee (No Refund)</strong></li>
                                  </ul>
                                </div>
                                
                                <p class="text-secondary small">Based on your check-in date of <strong><%= new Date(booking.checkIn).toLocaleDateString("en-IN") %></strong>, here is the refund calculation at the current time:</p>
                                
                                <div class="bg-light p-3 rounded-3 border mb-3">
                                  <div class="d-flex justify-content-between mb-2">
                                    <span class="text-secondary small">Total amount paid:</span>
                                    <span class="fw-bold text-dark small">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                  </div>
                                  <div class="d-flex justify-content-between mb-2 text-danger">
                                    <span class="small">Cancellation fee (<%= booking.feePercent %>%):</span>
                                    <span class="fw-bold small">- &#8377; <%= booking.cancellationFee.toLocaleString("en-IN") %></span>
                                  </div>
                                  <hr class="my-2 opacity-25">
                                  <div class="d-flex justify-content-between text-success">
                                    <span class="fw-bold small">Refundable amount:</span>
                                    <span class="fw-bold fs-5">&#8377; <%= booking.refundAmount.toLocaleString("en-IN") %></span>
                                  </div>
                                </div>

                                <p class="text-danger small fw-semibold mb-0"><i class="fa-solid fa-circle-info me-1"></i> This action is permanent and cannot be undone.</p>
                              </div>
                              <div class="modal-footer border-top p-3 d-flex justify-content-between">
                                <button type="button" class="btn btn-sm btn-secondary rounded-pill px-3" data-bs-dismiss="modal">Keep Booking</button>
                                <form action="/bookings/<%= booking._id %>/cancel" method="POST" class="d-inline">
                                  <button type="submit" class="btn btn-sm btn-danger rounded-pill px-3 fw-bold">
                                    Confirm &amp; Refund ₹<%= booking.refundAmount.toLocaleString("en-IN") %>
                                  </button>
                                </form>
                              </div>
                            </div>
                          </div>
                        </div>
                      <% } %>
                      <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm btn-outline-dark px-3 py-1.5 rounded-pill fw-bold">
                        <i class="fa-solid fa-eye me-1"></i>View Property
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
