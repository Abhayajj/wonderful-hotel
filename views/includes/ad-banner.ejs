<% if (process.env.ENABLE_GOOGLE_ADSENSE === "true") { %>
  <!-- Real Google AdSense Placement -->
  <div class="card border border-light-subtle shadow-sm rounded-4 overflow-hidden mb-4 p-3 text-center bg-light">
    <div class="d-flex align-items-center justify-content-between mb-2">
      <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5 fw-bold text-uppercase" style="font-size: 8px; letter-spacing: 0.5px;">Sponsored</span>
      <small class="text-muted" style="font-size: 10px;">Google AdSense</small>
    </div>
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=<%= process.env.GOOGLE_ADSENSE_CLIENT_ID %>" crossorigin="anonymous"></script>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client="<%= process.env.GOOGLE_ADSENSE_CLIENT_ID %>"
         data-ad-slot="default"
         data-ad-format="auto"
         data-full-width-responsive="true"></ins>
    <script>
         (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  </div>
<% } else { %>
  <% 
    // Curated list of premium, 100% family-friendly travel ads
    const premiumAds = [
      {
        title: "Fly Premium with Emirates",
        description: "Experience award-winning service, fine dining, and ultimate comfort on your next family vacation. Book today and get 10% off.",
        image: "https://images.unsplash.com/photo-1436491865332-7a61a109cc05?q=80&w=600&auto=format&fit=crop",
        cta: "Book Flight",
        link: "https://www.emirates.com"
      },
      {
        title: "Samsonite Travel Gear",
        description: "Pack more, worry less. Durable, lightweight travel luggage designed for long family adventures. Enjoy a lifetime warranty.",
        image: "https://images.unsplash.com/photo-1565026057447-bc90a3dbe297?q=80&w=600&auto=format&fit=crop",
        cta: "Shop Samsonite",
        link: "https://www.samsonite.com"
      },
      {
        title: "Allianz Family Travel Insurance",
        description: "Protect your family's travel plans with comprehensive coverage for cancellations, emergencies, and lost baggage.",
        image: "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?q=80&w=600&auto=format&fit=crop",
        cta: "Get Free Quote",
        link: "https://www.allianz.com"
      },
      {
        title: "Amex Gold Card for Travelers",
        description: "Earn 4x membership reward points on flights, hotels, and dining. Receive up to 60,000 welcome points upon approval.",
        image: "https://images.unsplash.com/photo-1589758438368-0ad531db3366?q=80&w=600&auto=format&fit=crop",
        cta: "Apply Now",
        link: "https://www.americanexpress.com"
      }
    ];

    // Pick an ad randomly using a stable random generation or pure random
    const adIndex = Math.floor(Math.random() * premiumAds.length);
    const selectedAd = premiumAds[adIndex];
    
    // Format for styling (horizontal or vertical sidebar style)
    const isSidebar = typeof sidebar !== 'undefined' && sidebar === true;
    const listingIdVal = typeof listingId !== 'undefined' && listingId ? listingId : null;
    // Generate a unique ID to prevent script clashes
    const adUniqueId = 'ad_' + Math.random().toString(36).substr(2, 9);
  %>

  <div id="<%= adUniqueId %>" class="card border border-light-subtle shadow-sm rounded-4 overflow-hidden mb-4 ad-placement" data-listing-id="<%= listingIdVal %>">
    <div class="row g-0 <%= isSidebar ? 'flex-column' : '' %>">
      
      <div class="<%= isSidebar ? 'col-12' : 'col-md-4 col-lg-3' %>">
        <img src="<%= selectedAd.image %>" class="img-fluid w-100" alt="Sponsored Ad" style="height: <%= isSidebar ? '12rem' : '100%' %>; min-height: <%= isSidebar ? '12rem' : '8.5rem' %>; object-fit: cover;">
      </div>
      
      <div class="<%= isSidebar ? 'col-12' : 'col-md-8 col-lg-9' %>">
        <div class="card-body p-3 h-100 d-flex flex-column justify-content-between">
          <div>
            <div class="d-flex align-items-center justify-content-between mb-1">
              <span class="badge bg-secondary text-white rounded-pill px-2 py-0.5 fw-bold text-uppercase" style="font-size: 8px; letter-spacing: 0.5px;">Sponsored</span>
              <small class="text-muted" style="font-size: 10px;">Family Friendly Ad</small>
            </div>
            <h6 class="card-title fw-bold text-dark mb-1"><%= selectedAd.title %></h6>
            <p class="card-text text-secondary small mb-2 text-truncate-2" style="font-size: 11.5px; line-height: 1.4;"><%= selectedAd.description %></p>
          </div>
          <div>
            <a href="<%= selectedAd.link %>" target="_blank" class="btn btn-sm btn-outline-danger rounded-pill px-3 fw-bold ad-cta-btn" style="font-size: 11px;"><%= selectedAd.cta %> <i class="fa-solid fa-arrow-up-right-from-square ms-1" style="font-size: 9px;"></i></a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    (function() {
      // Wrap in DOMContentLoaded or execute immediately with helper
      function initAd() {
        const adCard = document.getElementById('<%= adUniqueId %>');
        if (!adCard) return;

        const listingId = adCard.getAttribute('data-listing-id') || null;

        // Track Ad Impression via AJAX
        fetch('/dashboard/ads/track', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ type: 'impression', listingId: listingId })
        }).catch(err => console.error("Ad impression tracking error:", err));

        // Track Ad Click
        const ctaBtn = adCard.querySelector('.ad-cta-btn');
        if (ctaBtn) {
          ctaBtn.addEventListener('click', () => {
            fetch('/dashboard/ads/track', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ type: 'click', listingId: listingId })
            }).catch(err => console.error("Ad click tracking error:", err));
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAd);
      } else {
        initAd();
      }
    })();
  </script>

  <style>
    .text-truncate-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;  
      overflow: hidden;
    }
  </style>
<% } %>
