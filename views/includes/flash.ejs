<% if (success && success.length) { %>
  <div class="alert alert-success alert-dismissible fade show col-md-8 offset-md-2 border-0 shadow-sm rounded-3 py-3" role="alert">
    <div class="d-flex align-items-center gap-2">
      <i class="fa-solid fa-circle-check fs-5"></i>
      <div><%- success %></div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<% if (error && error.length) { %>
  <div class="alert alert-danger alert-dismissible fade show col-md-8 offset-md-2 border-0 shadow-sm rounded-3 py-3" role="alert">
    <div class="d-flex align-items-center gap-2">
      <i class="fa-solid fa-circle-exclamation fs-5"></i>
      <div><%- error %></div>
    </div>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>
